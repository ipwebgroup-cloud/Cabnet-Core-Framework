{
  "example_name": "Media Assets",
  "example_summary": "Asset management module showing upload fields, metadata, and searchable media records.",
  "feature_tags": ["uploads", "media", "assets"],
  "entity_key": "media_assets",
  "singular_label": "Media Asset",
  "plural_label": "Media Assets",
  "table": "media_assets",
  "fields": {
    "title": {"type": "text", "label": "Title", "required": true, "filterable": true},
    "asset_path": {"type": "file", "label": "Asset", "upload": true, "upload_dir": "media/assets", "required": true},
    "mime_type": {"type": "text", "label": "MIME Type", "required": false},
    "status": {
      "type": "select",
      "label": "Status",
      "options": {"draft": "Draft", "ready": "Ready"},
      "filterable": true
    }
  },
  "list_columns": ["id", "title", "mime_type", "status"],
  "searchable": ["title", "mime_type"],
  "default_order": "id DESC"
}
