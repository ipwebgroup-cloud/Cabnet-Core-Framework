<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ title|default('Cabnet Core Admin') }}</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        .admin-shell { min-height: 100vh; }
        .admin-sidebar { width: 260px; min-height: 100vh; }
        .admin-main { min-width: 0; }
        .nav-link-button {
            background: none;
            border: 0;
            padding: 0;
            text-align: left;
            width: 100%;
        }
        @media (max-width: 991.98px) {
            .admin-sidebar { width: 100%; min-height: auto; }
        }
    </style>
</head>
<body class="bg-body-tertiary">
{% set currentPath = currentPath|default('/') %}
{% set authUserData = authUser|default({}) %}
{% set isAuthenticated = authUserData is not empty %}
{% set logoutTarget = logoutAction|default('/logout') %}
{% set logoutToken = logoutCsrfToken|default('') %}
{% set menuItems = adminMenuItems|default([]) %}
<div class="d-lg-flex admin-shell">
    <aside class="admin-sidebar bg-dark text-white p-3">
        <div class="mb-4">
            <div class="fs-5 fw-semibold">Cabnet Core Admin</div>
            <div class="small text-white-50">v3.3 Twig parity convergence</div>
        </div>

        {% if isAuthenticated %}
            <nav class="nav flex-column gap-1">
                {% for item in menuItems %}
                    {% set requiresAuth = item.requires_auth|default(false) %}
                    {% if not requiresAuth or isAuthenticated %}
                        {% set path = item.path|default('#') %}
                        {% set match = item.match|default(path) %}
                        {% set method = item.method|default('GET')|upper %}
                        {% set active = match == '/' ? currentPath == '/' : currentPath starts with match %}
                        {% if method == 'POST' %}
                            <form method="post" action="{{ path }}" class="m-0">
                                <input type="hidden" name="_token" value="{{ logoutToken }}">
                                <button type="submit" class="nav-link nav-link-button text-white {{ active ? 'fw-bold' : '' }}">{{ item.label|default('Link') }}</button>
                            </form>
                        {% else %}
                            <a class="nav-link text-white {{ active ? 'fw-bold' : '' }}" href="{{ path }}">
                                {{ item.label|default('Link') }}
                            </a>
                        {% endif %}
                    {% endif %}
                {% endfor %}
            </nav>
        {% else %}
            <div class="small text-white-50">Sign in with an admin account to access the admin area.</div>
        {% endif %}
    </aside>

    <main class="admin-main flex-grow-1">
        <div class="border-bottom bg-white px-4 py-3">
            <div class="d-flex justify-content-between align-items-center gap-3 flex-wrap">
                <div>
                    <div class="fw-semibold">{{ title|default('Admin') }}</div>
                    <div class="small text-secondary">Src-owned admin Twig shell foundation</div>
                </div>
                {% if isAuthenticated %}
                    <div class="d-flex align-items-center gap-3">
                        <div class="text-end">
                            <div class="small text-secondary">Signed in as</div>
                            <div class="fw-semibold">{{ authUserData.name|default(authUserData.username|default('Administrator')) }}</div>
                        </div>
                        <form method="post" action="{{ logoutTarget }}" class="m-0">
                            <input type="hidden" name="_token" value="{{ logoutToken }}">
                            <button type="submit" class="btn btn-outline-dark btn-sm">Sign Out</button>
                        </form>
                    </div>
                {% endif %}
            </div>
        </div>

        <div class="p-4">
            {% include '@src/partials/flash.twig' %}
            {% block content %}{% endblock %}
        </div>
    </main>
</div>
</body>
</html>
