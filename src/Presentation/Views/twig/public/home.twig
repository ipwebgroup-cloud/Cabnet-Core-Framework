{% extends '@src/layouts/public.twig' %}

{% block content %}
<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="card shadow-sm border-0">
            <div class="card-body p-4">
                <h1 class="h3 mb-3">{{ appName }}</h1>
                <p class="text-secondary">Public starter controller, session layer, flash system, and the shared src Twig presentation shell are working.</p>
                <dl class="row mb-0">
                    <dt class="col-sm-3">Context</dt>
                    <dd class="col-sm-9">{{ context }}</dd>
                    <dt class="col-sm-3">Timestamp</dt>
                    <dd class="col-sm-9">{{ now }}</dd>
                </dl>
            </div>
        </div>
    </div>
</div>
{% endblock %}
